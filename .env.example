# ── RIYA environment ─────────────────────────────────────────────
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# AI brain provider: "openai" (cloud, needs key) or "ollama" (local, free).
RIYA_PROVIDER=openai

# OpenAI (the AI brain). Get a key at https://platform.openai.com/api-keys
# Only required when RIYA_PROVIDER=openai.
OPENAI_API_KEY=

# Model id.
#  - OpenAI: gpt-4o, gpt-4o-mini, gpt-4.1, etc.
#  - Ollama: a locally pulled model, e.g. llama3.2, gemma4:latest (see `ollama list`)
RIYA_MODEL=gpt-4o-mini

# Optional API base URL override. Leave blank for the provider default.
# Ollama default is http://localhost:11434/v1
RIYA_BASE_URL=

# Backend server
RIYA_HOST=127.0.0.1
RIYA_PORT=8000

# Comma-separated origins allowed to call the API (the Electron dev server)
RIYA_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
